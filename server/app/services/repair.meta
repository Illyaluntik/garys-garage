{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/services/layout,_N_T_/services/repair/layout,_N_T_/services/repair/page,_N_T_/services/repair"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/services/repair/__PAGE__",
    "/services/repair",
    "/services",
    "/_index",
    "/_head"
  ]
}