{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/services/layout,_N_T_/services/hauling/layout,_N_T_/services/hauling/page,_N_T_/services/hauling"
  },
  "segmentPaths": [
